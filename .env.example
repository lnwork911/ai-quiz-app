# Copy this file to `.env` for local Netlify Dev (never commit real secrets).
# Netlify UI → Site settings → Environment variables mirrors these keys in production.

# OpenAI (required for quiz generation)
OPENAI_API_KEY=sk-...
# Optional override (defaults to gpt-4o-mini in code)
# OPENAI_MODEL=gpt-4o-mini

# Netlify Identity JWT secret (required for verifying users in Functions)
# Netlify → Identity → Settings → Services → JWT secret
JWT_SECRET=your-identity-jwt-secret

# Upstash Redis (optional — caching is skipped when unset)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# Stripe (required for subscription checkout buttons on pricing.html)
STRIPE_SECRET_KEY=sk_live_or_test_...

# Stripe Price IDs for each plan (create recurring Prices in Stripe Dashboard)
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_SCHOOL=price_...

# Optional: quiz cache TTL in seconds (default 86400 = 24h)
# QUIZ_CACHE_TTL_SECONDS=86400
